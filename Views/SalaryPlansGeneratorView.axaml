             x:CompileBindings="False">
    <ScrollViewer>
        <StackPanel Spacing="16">
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <!-- <TextBlock Text="Consulta DAX" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="Usa el dataset ya configurado o pega uno manualmente." Foreground="#6B6B5F"/>
                    <TextBox Text="{Binding DatasetId}" Watermark="Dataset ID"/>
                    <TextBox Text="{Binding DaxQuery}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="220"/>
                    <Button Content="Ejecutar" Command="{Binding ExecuteCommand}" HorizontalAlignment="Left"/> -->
                </StackPanel>
            </Border>



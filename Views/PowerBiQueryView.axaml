<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Zenit.Views.PowerBiQueryView"
             x:CompileBindings="False">
    <ScrollViewer>
        <StackPanel Spacing="16">
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="Consulta DAX" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="Usa el dataset ya configurado o pega uno manualmente." Foreground="#6B6B5F"/>
                    <TextBox Text="{Binding DatasetId}" Watermark="Dataset ID"/>
                    <TextBox Text="{Binding DaxQuery}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="220"/>
                    <Button Content="Ejecutar" Command="{Binding ExecuteCommand}" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="JSON response" FontSize="20" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding JsonResponse}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Courier New"
                             IsReadOnly="True"
                             MinHeight="320"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

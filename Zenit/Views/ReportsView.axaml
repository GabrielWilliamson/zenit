<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Zenit.Views.ReportsView"
             x:CompileBindings="False">
    <ScrollViewer>
        <StackPanel Spacing="16">
            <Border Classes="card" IsVisible="{Binding IsStatusOpen}">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding StatusTitle}" FontWeight="SemiBold" FontSize="18"/>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="14">
                    <TextBlock Text="Filtros y ejecucion" FontSize="20" FontWeight="SemiBold"/>
                    <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                            <TextBlock Text="Reporte"/>
                            <ComboBox ItemsSource="{Binding ReportOptions}" SelectedItem="{Binding SelectedReport}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                            <TextBlock Text="Mes"/>
                            <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Spacing="6">
                            <TextBlock Text="Año"/>
                            <ComboBox ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="3" Spacing="6">
                            <TextBlock Text="Grupo"/>
                            <ComboBox ItemsSource="{Binding GrupoOptions}" SelectedItem="{Binding SelectedGrupo}" IsEnabled="{Binding IsGrupoAvailable}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Spacing="6">
                            <TextBlock Text="Vendedores (CSV)" />
                            <TextBox Text="{Binding SelectedCodVendsCsv}" Watermark="Ej: 018, 021, 031"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="3" Spacing="6">
                            <TextBlock Text="Filas por página"/>
                            <ComboBox ItemsSource="{Binding PageSizes}" SelectedItem="{Binding SelectedPageSize}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="12">
                            <Button Content="Recargar filtros" Command="{Binding ReloadFiltersCommand}"/>
                            <Button Content="Ejecutar reporte" Command="{Binding RunReportCommand}"/>
                            <Button Content="Exportar PDF" Command="{Binding ExportPdfCommand}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding DatasetName, StringFormat='Dataset: {0}'}"/>
                    <TextBlock Text="{Binding CodVendSelectionText}"/>
                    <TextBlock Text="{Binding PagingSummary}" Foreground="#6B6B5F"/>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Primera" Command="{Binding FirstPageCommand}"/>
                        <Button Content="Anterior" Command="{Binding PrevPageCommand}"/>
                        <Button Content="Siguiente" Command="{Binding NextPageCommand}"/>
                        <Button Content="Última" Command="{Binding LastPageCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="Vista previa tabular" FontSize="20" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding ResultsPreview}"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             FontFamily="Courier New"
                             IsReadOnly="True"
                             MinHeight="280"/>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="WhatsApp" FontSize="20" FontWeight="SemiBold"/>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                            <TextBlock Text="Numero para mensaje"/>
                            <TextBox Text="{Binding WhatsAppPhoneNumber}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                            <TextBlock Text="Mensaje"/>
                            <TextBox Text="{Binding WhatsAppMessageText}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                            <TextBlock Text="Numero para archivo"/>
                            <TextBox Text="{Binding WhatsAppFilePhoneNumber}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                            <TextBlock Text="Path archivo"/>
                            <TextBox Text="{Binding WhatsAppFilePath}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Spacing="6">
                            <TextBlock Text="Caption"/>
                            <TextBox Text="{Binding WhatsAppFileCaption}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Enviar mensaje" Command="{Binding SendWhatsAppMessageCommand}"/>
                        <Button Content="Enviar archivo" Command="{Binding SendWhatsAppFileCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
